export BASE_DIR="/path/to/PLMGuard"
export DATA_DIR="$BASE_DIR/data"
export TEMP_DIR="$DATA_DIR/temp"
export EVALPLMS_PYTHON_PATH="/path/to/evalPLMs/bin/python"

## BLASTP
export BLASTP_PYTHON_PATH="/path/to/evalPLMs/bin/python"
export BLASTP_NUM_PARALLEL=10

## DCT_DOMAIN
export DCT_DOMAIN_PYTHON_PATH="/path/to/dctdomain/bin/python"
export DCT_DOMAIN_SRC_DIR="$BASE_DIR/libs/DCTdomain"
export DCT_DOMAIN_GPU_DEVICES="5,6,7"
export DCT_DOMAIN_NUM_PARALLEL=1

## DHR
export DHR_PYTHON_PATH="/path/to/dhr/bin/python"
export DHR_SRC_DIR="$BASE_DIR/libs/Dense-Homolog-Retrieval-main"
export DHR_GPU_DEVICES="6"
export DHR_NUM_PARALLEL=1

## PLMsearch
export PLMSEARCH_PYTHON_PATH="/path/to/fastMSA/bin/python"
export PLMSEARCH_SRC_DIR="$BASE_DIR/libs/PLMSearch-main"
export PLMSEARCH_GPU_DEVICES="5"
export PLMSEARCH_NUM_PARALLEL=1

## tmvec
export TMVEC_PYTHON_PATH="/path/to/tmvec/bin/python"
export TMVEC_SRC_DIR="$BASE_DIR/libs/tm-vec-master"
export TMVEC_GPU_DEVICES="3"
export TMVEC_NUM_PARALLEL=1

## MMseqs2
export MMSEQ2_PYTHON_PATH="/path/to/evalPLMs/bin/python"
export MMSEQ2_GPU_DEVICES="2,3,4"

## NEAR
export NEAR_PYTHON_PATH="/path/to/near_env/bin/python"
export NEAR_SRC_DIR="$BASE_DIR/libs/NEAR"
export NEAR_GPU_DEVICES="2,3,4"

## Diamond
export DIAMOND_PYTHON_PATH="/path/to/evalPLMs/bin/python"
export DIAMOND_SRC_DIR="$BASE_DIR/libs"